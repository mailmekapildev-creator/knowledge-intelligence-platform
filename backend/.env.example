# Copy to .env and fill in for a real (non-mock) deployment.

MOCK_MODE=true

# Auth
JWT_SECRET=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=15

# LLM
ANTHROPIC_API_KEY=
LLM_MODEL_PRIMARY=claude-sonnet-5
LLM_MODEL_FALLBACK=claude-haiku-4-5-20251001

# Infra (only needed when MOCK_MODE=false)
DATABASE_URL=postgresql+asyncpg://kip:kip@localhost:5432/kip
REDIS_URL=redis://localhost:6379/0

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
